<view class="page">
  <view class="section">
    <view class="section-title">查询验证码</view>
    <view class="input-row">
      <input class="input" 
             placeholder="输入 SessionID" 
             value="{{sessionId}}" 
             bindinput="onSessionInput"
             bindconfirm="onQuery" />
      <view class="clear" wx:if="{{sessionId}}" bindtap="onClear">清除</view>
    </view>
    <view class="btn {{!sessionId || loading ? 'btn-disabled' : ''}}" bindtap="onQuery">
      {{loading ? '查询中...' : '查询'}}
    </view>
  </view>

  <view class="result" wx:if="{{code}}">
    <view class="result-label">验证码</view>
    <view class="result-code">{{code}}</view>
    <view class="result-tip">在网页端输入此验证码完成验证</view>
  </view>

  <view class="error" wx:if="{{error}}">
    <text>{{error}}</text>
  </view>

  <view class="tip" wx:if="{{!code && !error}}">
    <text>SessionID 在网页二维码下方查看</text>
  </view>
</view>

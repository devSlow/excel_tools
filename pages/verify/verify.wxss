.page {
  padding: 40rpx 32rpx;
  background: #f5f7fa;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e0e0e0;
  padding-bottom: 20rpx;
  margin-bottom: 32rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #333;
}

.clear {
  font-size: 26rpx;
  color: #999;
  padding: 12rpx 20rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  background: #1677ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-disabled {
  opacity: 0.5;
}

.result {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.result-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.result-code {
  font-size: 96rpx;
  font-weight: 700;
  color: #1677ff;
  letter-spacing: 12rpx;
  margin-bottom: 20rpx;
}

.result-tip {
  font-size: 26rpx;
  color: #666;
}

.error {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #fff2f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #ff4d4f;
}

.loading {
  margin-top: 32rpx;
  text-align: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #1677ff;
}

.tip {
  margin-top: 60rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

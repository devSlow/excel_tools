page {
  background: #f5f7fa;
  height: 100%;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e6f4ff 0%, #f5f7fa 30%);
  padding: 0 32rpx;
  box-sizing: border-box;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
}

.avatar-wrapper {
  margin-bottom: 24rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(22, 119, 255, 0.35);
}

.avatar text {
  font-size: 52rpx;
  color: #fff;
  font-weight: 600;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nickname {
  font-size: 38rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.user-tip {
  font-size: 26rpx;
  color: #999;
}

.card-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #10b556 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
  padding: 0;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 1;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #07c160;
  font-weight: 700;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #fff;
  border-right-color: #fff;
  border-bottom-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  margin-right: 16rpx;
}

.loading-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.login-hint {
  text-align: center;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

.link {
  color: #1677ff;
  margin: 0 4rpx;
}

.loading-hint {
  color: #07c160;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.menu-section {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-top: 100rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: #fff;
  border: none;
  width: 100%;
  box-sizing: border-box;
}

.menu-item::after {
  border: none;
}

.menu-text {
  color: #333;
  font-size: 30rpx;
}

.logout-text {
  color: #666;
}

.menu-section .menu-item:first-child {
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #fff;
  border: none;
  width: 100%;
  box-sizing: border-box;
}

.menu-item::after {
  border: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
  text-align: center;
}

.menu-arrow {
  display: none;
}

.logout-section {
  margin-top: 32rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.logout-text {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.app-info {
  display: flex;
  justify-content: center;
  padding: 60rpx 30rpx;
  position: relative;
  z-index: 10;
}

.version {
  font-size: 22rpx;
  color: #bbb;
  padding: 20rpx;
}

.version {
  font-size: 22rpx;
  color: #bbb;
}

.trigger-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  z-index: 1;
}

<view class="container">
  <view class="loading-mask" wx:if="{{initialLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  <view class="header">
    <view class="header-left">
      <view class="greeting">您好</view>
      <view class="date">{{currentDate}}</view>
    </view>
    <view class="header-right {{showSearch ? 'header-search-active' : ''}}">
      <view class="header-search-icon-wrap" catchtap="onSearchTap">
        <image class="header-search-icon" src="data:image/svg+xml;base64," mode="aspectFit" />
      </view>
      <view class="header-search-bar">
        <icon type="search" size="14" color="#999999" />
        <input class="header-search-input" placeholder="搜索任务名称..." placeholder-class="search-placeholder" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearch" bindblur="onSearchBlur" confirm-type="search" focus="{{showSearch}}" />
        <view class="header-search-close" catchtap="onSearchClose">
          <icon type="clear" size="12" color="#ffffff" />
        </view>
      </view>
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-icon-wrap">
        <image class="stat-icon-img" src="data:image/svg+xml;base64," mode="aspectFit" />
      </view>
      <view class="stat-num">{{totalTasks}}</view>
      <view class="stat-label">任务总数</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-icon-wrap">
        <image class="stat-icon-img" src="data:image/svg+xml;base64," mode="aspectFit" />
      </view>
      <view class="stat-num">{{totalRows}}</view>
      <view class="stat-label">数据总量</view>
    </view>
  </view>
  <view class="export-tip">点击导出后预览文件，点击右上角···可转发保存</view>

  <view class="filter-bar">
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view class="filter-item {{filterDate === 'all' ? 'active' : ''}}" catchtap="onFilterDate" data-value="all">
        <view class="filter-dot"></view>
        <text>全部</text>
      </view>
      <view class="filter-item {{filterDate === 'today' ? 'active' : ''}}" catchtap="onFilterDate" data-value="today">
        <view class="filter-dot"></view>
        <text>今天</text>
      </view>
      <view class="filter-item {{filterDate === 'week' ? 'active' : ''}}" catchtap="onFilterDate" data-value="week">
        <view class="filter-dot"></view>
        <text>本周</text>
      </view>
      <view class="filter-item {{filterDate === 'month' ? 'active' : ''}}" catchtap="onFilterDate" data-value="month">
        <view class="filter-dot"></view>
        <text>本月</text>
      </view>
      <view class="filter-item {{filterDate === 'custom' ? 'active' : ''}}" catchtap="onFilterDate" data-value="custom">
        <view class="filter-dot"></view>
        <text>自定义</text>
      </view>
    </scroll-view>
  </view>

  <view class="custom-date-wrap" wx:if="{{filterDate === 'custom'}}">
    <picker mode="date" value="{{filterStartDate}}" start="2020-01-01" end="{{filterEndDate}}" bindchange="onStartDateChange">
      <view class="date-picker-input">
        <text class="date-label">从</text>
        <text class="date-value">{{filterStartDate || '选择开始日期'}}</text>
      </view>
    </picker>
    <picker mode="date" value="{{filterEndDate}}" start="{{filterStartDate}}" end="2030-12-31" bindchange="onEndDateChange">
      <view class="date-picker-input">
        <text class="date-label">至</text>
        <text class="date-value">{{filterEndDate || '选择结束日期'}}</text>
      </view>
    </picker>
    <view class="confirm-btn" catchtap="onCustomDateConfirm">筛选</view>
  </view>

   <view class="filter-result" wx:if="{{filterDate !== 'all'}}">
    <text class="filter-result-text" wx:if="{{filterDate === 'today'}}">今天 · 共 {{taskList.length}} 条任务</text>
    <text class="filter-result-text" wx:elif="{{filterDate === 'week'}}">本周 · 共 {{taskList.length}} 条任务</text>
    <text class="filter-result-text" wx:elif="{{filterDate === 'month'}}">本月 · 共 {{taskList.length}} 条任务</text>
    <text class="filter-result-text" wx:elif="{{filterDate === 'custom' && filterStartDate && filterEndDate}}">{{filterStartDate}} ~ {{filterEndDate}} · 共 {{taskList.length}} 条任务</text>
    <view class="filter-reset" catchtap="onFilterReset">重置</view>
  </view>

  <view class="content-area {{taskList.length === 0 && !initialLoading ? 'content-area-center' : ''}}">
    <view class="task-list" wx:if="{{taskList.length > 0}}">
      <view class="task-item" wx:for="{{taskList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="task-top">
          <view class="task-name-wrap">
            <view class="task-name">{{item.name}}</view>
          </view>
          <view class="task-status {{item.status}}">{{item.statusText}}</view>
        </view>
        <view class="task-meta">
          <view class="meta-item">
            <view class="meta-icon meta-icon-data"></view>
            <text class="meta-text">{{item.rowCount}} 条数据</text>
          </view>
          <view class="meta-item">
            <view class="meta-icon meta-icon-time"></view>
            <text class="meta-text">{{item.createTime}}</text>
          </view>
        </view>
        <view class="task-actions">
          <view class="action-btn export-btn" catchtap="handleExport" data-id="{{item.id}}" data-name="{{item.name}}">
            <icon type="download" size="13" color="#1677ff" />
            <text>导出</text>
          </view>
          <view class="action-btn delete-btn" catchtap="handleDelete" data-id="{{item.id}}">
            <icon type="clear" size="13" color="#ff4d4f" />
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{taskList.length === 0 && !initialLoading}}">
      <view class="empty-content {{!isLoggedIn ? 'empty-content-masked' : ''}}">
        <image class="empty-icon" src="/images/empty-task.png" mode="aspectFit" />
        <view class="empty-text">暂无解析任务</view>
        <view class="empty-hint">粘贴需要拆分的数据 即可生成Excel</view>
        <view class="empty-actions" wx:if="{{isLoggedIn}}">
          <view class="empty-btn" bindtap="goToParse">去解析</view>
        </view>
      </view>
      <view class="empty-login-mask" wx:if="{{!isLoggedIn}}">
        <view class="mask-glass">
          <view class="mask-icon-wrap">
            <image class="mask-icon-svg" src="/images/tips.png" mode="aspectFit" />
          </view>
          <view class="mask-title">登录后查看任务</view>
          <view class="mask-desc">登录后可查看和管理您的解析任务</view>
          <view class="mask-btn" catchtap="goToLogin">立即登录</view>
          <view class="mask-footer">登录后即可使用完整功能</view>
        </view>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{taskList.length > 0}}">
    <view wx:if="{{loading}}" class="load-more-inner">
      <view class="loading-spinner-small"></view>
      <text>加载中...</text>
    </view>
    <view wx:elif="{{noMore}}" class="load-more-end">— 没有更多了 —</view>
  </view>

  <view class="update-mask" wx:if="{{showUpdateModal}}" catchtap="closeUpdateModal">
    <view class="update-dialog" catchtap="">
      <view class="update-header">
        <view class="update-badge">v{{updateInfo.version}}</view>
        <text class="update-title">发现新版本</text>
      </view>
      <image wx:if="{{updateInfo.updateImage}}" class="update-image" src="{{updateInfo.updateImage}}" mode="aspectFill" />
      <view class="update-content" wx:if="{{updateInfo.updateContent}}">
        <view class="update-line" wx:for="{{updateInfo.updateContent.split('\\n')}}" wx:key="index" wx:if="{{item}}">
          {{item}}
        </view>
      </view>
      <view class="update-footer">
        <view class="update-btn" catchtap="closeUpdateModal">知道了</view>
      </view>
    </view>
  </view>
</view>

<view class="container">
  <view class="loading-mask" wx:if="{{initialLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  <view class="header">
    <view class="header-left">
      <view class="greeting">您好</view>
      <view class="date">{{currentDate}}</view>
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-value">{{totalTasks}}</view>
      <view class="stat-label">任务总数</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{totalRows}}</view>
      <view class="stat-label">数据总量</view>
    </view>
  </view>
  <view class="export-tip">点击导出后预览文件，点击右上角···可转发保存</view>

  <view class="section-title">
    <text>我的任务</text>
  </view>

  <view class="search-box">
    <view class="search-input-wrap">
      <icon type="search" size="16" color="#999999" />
      <input class="search-input" placeholder="搜索解析内容..." value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" bindclear="onSearchClear" />
      <view class="search-clear" wx:if="{{searchKeyword}}" catchtap="onSearchClear">
        <icon type="clear" size="14" color="#999999" />
      </view>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <view class="loading-more" wx:if="{{searchLoading}}">
    <view class="loading-spinner-small"></view>
    <text>搜索中...</text>
  </view>

  <view class="task-list" wx:if="{{taskList.length > 0}}">
    <view class="task-item" wx:for="{{taskList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="task-header">
        <view class="task-name">{{item.name}}</view>
        <view class="task-status {{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="task-info">
        <view class="task-info-item">
          <icon type="info" size="14" color="#1677ff" />
          <text>{{item.rowCount}} 条数据</text>
        </view>
        <view class="task-info-item">
          <icon type="waiting" size="14" color="#1677ff" />
          <text>{{item.createTime}}</text>
        </view>
      </view>
      <view class="task-actions">
        <view class="action-btn" catchtap="handleExport" data-id="{{item.id}}" data-name="{{item.name}}">
          <icon type="download" size="14" color="#1677ff" />
          <text>导出</text>
        </view>
        <view class="action-btn delete" catchtap="handleDelete" data-id="{{item.id}}">
          <icon type="clear" size="14" color="#ff4d4f" />
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon">
      <icon type="info" size="40" color="#d9d9d9" />
    </view>
    <view class="empty-text">暂无解析任务</view>
  </view>

  <view class="load-more" wx:if="{{taskList.length > 0}}">
    <view wx:if="{{loading}}">加载中...</view>
    <view wx:elif="{{noMore}}">没有更多了</view>
  </view>
</view>
page {
  background: #f5f7fa;
  height: 100%;
}

.container {
  min-height: 100%;
  background: linear-gradient(180deg, #e6f4ff 0%, #f5f7fa 30%);
  padding: 32rpx;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
}

.content-area {
  flex:1;
}

.content-area-center {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-left .greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.header-left .date {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.header-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 72rpx;
  position: relative;
}

.header-search-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transform: scale(1);
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.header-search-active .header-search-icon-wrap {
  opacity: 0;
  transform: scale(0.5);
  width: 0;
  overflow: hidden;
}

.header-search-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 8rpx;
}

.header-search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 12rpx;
  width: 0;
  opacity: 0;
  overflow: hidden;
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
  position: absolute;
  right: 0;
}

.header-search-active .header-search-bar {
  width: 400rpx;
  opacity: 1;
}

.filter-bar {
  background: #fff;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.filter-scroll {
  white-space: nowrap;
  width: 100%;
}

.filter-scroll::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  background: #f5f7fa;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.25s ease;
  position: relative;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item .filter-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c0c4cc;
  transition: all 0.25s ease;
}

.filter-item.active {
  background: linear-gradient(135deg, #e6f4ff, #bae0ff);
  color: #1677ff;
  font-weight: 500;
}

.filter-item.active .filter-dot {
  background: #1677ff;
  box-shadow: 0 0 8rpx rgba(22, 119, 255, 0.3);
}

.custom-date-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.date-picker-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-label {
  font-size: 24rpx;
  color: #999;
}

.date-value {
  font-size: 24rpx;
  color: #333;
}

.confirm-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.25);
}

.confirm-btn:active {
  opacity: 0.85;
}

.filter-result {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border-left: 6rpx solid #1677ff;
}

.filter-result-text {
  font-size: 24rpx;
  color: #666;
}

.filter-reset {
  font-size: 24rpx;
  color: #1677ff;
  padding: 4rpx 16rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
}

.filter-reset:active {
  background: #dce8ff;
}

.task-list-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  border-radius: 16rpx;
}


.header-search-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transform: scale(1);
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.header-filter-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transform: scale(1);
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.header-filter-icon {
  width: 56rpx;
  height: 56rpx;
}

.header-search-active .header-search-icon-wrap,
.header-filter-active .header-filter-icon-wrap {
  opacity: 0;
  transform: scale(0.5);
  width: 0;
  overflow: hidden;
}

.header-search-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 8rpx;
}

.header-filter-bar {
  display: none;
  position: absolute;
  right: 0;
  top: 8rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  z-index: 10;
}

.header-filter-expanded .header-filter-bar {
  display: block;
  width: 520rpx;
}

.filter-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-item {
  padding: 10rpx 24rpx;
  background: #f0f2f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-item.active {
  background: #1677ff;
  color: #fff;
}

.custom-date-wrap {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker-input {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.confirm-btn {
  padding: 12rpx 28rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.header-search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 12rpx;
  width: 0;
  opacity: 0;
  overflow: hidden;
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
  position: absolute;
  right: 0;
}

.header-search-active .header-search-bar {
  width: 400rpx;
  opacity: 1;
}

.header-filter-bar {
  display: none;
  position: absolute;
  right: 0;
  top: 8rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  z-index: 10;
}

.header-filter-active .header-filter-bar {
  display: block;
  width: 520rpx;
}

.header-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 40rpx;
  line-height: 40rpx;
  min-width: 0;
}

.header-search-close {
  width: 36rpx;
  height: 36rpx;
  background: #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
}

.stats-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 50%, #69b4ff 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.stats-card::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -30rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.stat-icon-text {
  font-size: 36rpx;
}

.stat-icon-img {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

.stat-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  margin-top: 16rpx;
}

.export-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 32rpx;
}

/* === Section Title === */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-title-count {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

/* === Task List === */
.task-list {
  width: 100%;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.task-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.task-item:active {
  transform: scale(0.985);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

/* Task Top: name + status */
.task-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.task-name-wrap {
  flex: 1;
  margin-right: 16rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  word-break: break-all;
}

.task-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.task-status.completed {
  background: #e6f7ff;
  color: #1890ff;
}

.task-status.processing {
  background: #fff7e6;
  color: #fa8c16;
}

.task-status.draft {
  background: #f5f5f5;
  color: #999;
}

/* Task Meta: data count + time */
.task-meta {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.meta-icon-data {
  background: #1677ff;
}

.meta-icon-time {
  background: #fa8c16;
}

.meta-text {
  font-size: 24rpx;
  color: #888;
}

/* Task Actions: export + delete */
.task-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  padding: 14rpx 0;
  border-radius: 10rpx;
  transition: background 0.15s;
}

.export-btn {
  color: #1677ff;
  background: #f0f5ff;
}

.export-btn:active {
  background: #dce8ff;
}

.delete-btn {
  color: #ff4d4f;
  background: #fff1f0;
}

.delete-btn:active {
  background: #ffccc7;
}

/* === Empty State === */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-content-masked {
  opacity: 0.3;
  pointer-events: none;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.empty-icon-svg {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

.empty-btn {
  background: #1677ff;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  margin-bottom: 16rpx;
}

.empty-btn-tip {
  font-size: 24rpx;
  color: #999;
}

.empty-state-masked {
  opacity: 0.25;
}

.empty-login-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  background: rgba(245, 247, 250, 0.65);
  backdrop-filter: blur(20rpx);
}

.mask-glass {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.08), 0 4rpx 20rpx rgba(22, 119, 255, 0.06);
  margin: 0 60rpx;
  width: calc(100% - 120rpx);
  max-width: 520rpx;
}

.mask-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.mask-icon-svg {
  width: 88rpx;
  height: 88rpx;
}

.mask-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.mask-desc {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.mask-btn {
  width: 100%;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  text-align: center;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
  letter-spacing: 1rpx;
}

.mask-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.mask-footer {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #c0c4cc;
}

.empty-icon {
  display: block;
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
}

/* === Load More === */
.load-more {
  padding: 32rpx 0;
  text-align: center;
}

.load-more-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #999;
}

.load-more-end {
  font-size: 24rpx;
  color: #ccc;
  padding: 16rpx 0;
}

.update-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.update-dialog {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.update-header {
  padding: 36rpx 32rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.update-badge {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.update-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.update-image {
  width: 100%;
  height: 300rpx;
}

.update-content {
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.8;
}

.update-line {
  padding: 4rpx 0;
}

.update-footer {
  padding: 16rpx 32rpx 32rpx;
}

.update-btn {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.update-btn:active {
  opacity: 0.85;
}

.service-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.service-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.service-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.service-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.service-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
}

.service-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 28rpx;
  color: #c0c4cc;
}
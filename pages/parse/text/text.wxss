page {
  background: #f5f7fa;
  height: 100%;
}

.container {
  min-height: 100%;
  background: #f5f7fa;
  padding: 32rpx;
  box-sizing: border-box;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.text-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.delimiter-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.delimiter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.delimiter-option {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.delimiter-option.active {
  background: #1677ff;
  color: #fff;
}

.parse-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
}

.parse-btn::after {
  border: none;
}

.parse-btn[disabled] {
  opacity: 0.6;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.btn-row .parse-btn,
.btn-row .export-btn {
  flex: 1;
}

.export-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border: 2rpx solid #1677ff;
  border-radius: 48rpx;
  color: #1677ff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.export-btn::after {
  border: none;
}

.export-btn[disabled] {
  opacity: 0.6;
}

.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 0;
}

.result-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1677ff;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.result-info {
  font-size: 24rpx;
  color: #999;
}

.preview-actions {
  margin-bottom: 16rpx;
}

.preview-actions .action-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.action-btn::after {
  border: none;
}

.table-wrapper {
  height: 500rpx;
  overflow: hidden;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
}

.data-table {
  display: flex;
  flex-direction: column;
  min-width: max-content;
}

.table-header {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 10;
}

.th {
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-right: 1rpx solid rgba(255,255,255,0.3);
  min-width: 120rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.th:last-child {
  border-right: none;
}

.table-body {
  flex: 1;
  overflow-y: auto;
}

.table-body .tr {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.table-body .tr:nth-child(even) {
  background: #fafafa;
}

.table-body .tr:nth-child(odd) {
  background: #fff;
}

.table-body .tr:active {
  background: #e6f4ff;
}

.row-index {
  width: 70rpx;
  min-width: 70rpx;
  padding: 16rpx 8rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  background: #f5f5f5;
  border-right: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.td {
  padding: 16rpx 12rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  border-right: 1rpx solid #f5f5f5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 120rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.td:last-child {
  border-right: none;
}

.more-tip {
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f7fa;
  border-radius: 8rpx;
  margin-top: 8rpx;
}
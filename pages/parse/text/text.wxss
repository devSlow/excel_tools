.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 32rpx;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.text-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.delimiter-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.delimiter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.delimiter-option {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.delimiter-option.active {
  background: #667eea;
  color: #fff;
}

.parse-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.parse-btn::after {
  border: none;
}

.parse-btn[disabled] {
  opacity: 0.6;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.btn-row .parse-btn,
.btn-row .export-btn {
  flex: 1;
}

.export-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border: 2rpx solid #667eea;
  border-radius: 48rpx;
  color: #667eea;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.export-btn::after {
  border: none;
}

.export-btn[disabled] {
  opacity: 0.6;
}

.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-info {
  font-size: 24rpx;
  color: #999;
}

.table-wrapper {
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.data-table {
  min-width: 100%;
  display: inline-block;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx 8rpx 0 0;
}

.th {
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  background: #f5f5f5;
  border-right: 1rpx solid #e0e0e0;
}

.table-body .tr {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-body .tr:last-child {
  border-bottom: none;
}

.td {
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 24rpx;
}

.preview-actions .action-btn {
  flex: 1;
  height: 80rpx;
  background: #667eea;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}
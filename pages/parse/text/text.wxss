page {
  background: linear-gradient(180deg, #e6f4ff 0%, #f5f7fa 30%);
  height: 100%;
  overflow-y: auto;
}

.banner-swiper {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.4s ease-in;
}

.banner-image.loaded {
  opacity: 1;
}

.banner-skeleton {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  background: #f5f7fa;
  padding: 0;
}

.skeleton-item {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, #fafafa 25%, #f5f5f5 50%, #fafafa 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.container {
  min-height: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
  position: relative;
}



.notice-icon {
  font-size: 36rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1677ff;
}

.notice-hint {
  margin-left: auto;
  font-size: 24rpx;
  color: #69b1ff;
}

.notice-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
}

.notice-text-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.delimiter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding-left: 20rpx;
}

.delimiter-tag {
  font-size: 22rpx;
  color: #1677ff;
  background: rgba(255, 255, 255, 0.7);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #bae0ff;
}

.example-section {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  padding: 20rpx;
}

.example-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1677ff;
  margin-bottom: 12rpx;
}

.example-box {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.example-text {
  font-size: 24rpx;
  color: #595959;
  font-family: 'Courier New', monospace;
  background: #f5f5f5;
  padding: 10rpx 16rpx;
  border-radius: 6rpx;
}

.input-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.text-input {
  width: 100%;
  height: 500rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafbfc;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #e8e8e8;
  overflow-y: auto;
}



.delimiter-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.delimiter-options {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.delimiter-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.delimiter-option .option-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.delimiter-option .option-text {
  font-size: 24rpx;
  color: #666;
}

.delimiter-option.active {
  background: #e6f4ff;
  border-color: #1677ff;
}

.delimiter-option.active .option-text {
  color: #1677ff;
  font-weight: 500;
}

.parse-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.35);
  margin-bottom: 24rpx;
}

.parse-btn::after {
  border: none;
}

.parse-btn[disabled] {
  opacity: 0.5;
}

.preview-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-header .section-title {
  margin-bottom: 0;
}

.result-stats {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
}

.result-stats .stat-item {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.result-stats .stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1677ff;
}

.result-stats .stat-label {
  font-size: 24rpx;
  color: #666;
}

.result-stats .stat-divider {
  width: 1rpx;
  height: 32rpx;
  background: #d9d9d9;
  margin: 0 16rpx;
}

.preview-actions {
  margin-bottom: 20rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(82, 196, 26, 0.35);
}

.save-btn::after {
  border: none;
}

.table-wrapper {
  height: 480rpx;
  overflow: hidden;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
}

.data-table {
  display: flex;
  flex-direction: column;
  min-width: max-content;
}

.table-header {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 10;
}

.th {
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  background: linear-gradient(135deg, #595959 0%, #8c8c8c 100%);
  border-right: 1rpx solid rgba(255,255,255,0.2);
  min-width: 100rpx;
}

.th.row-num {
  width: 64rpx;
  min-width: 64rpx;
  background: #404040;
}

.th:last-child {
  border-right: none;
}

.table-body .tr {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-body .tr:nth-child(even) {
  background: #fafafa;
}

.table-body .tr:nth-child(odd) {
  background: #fff;
}

.td {
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
  border-right: 1rpx solid #f5f5f5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.td.row-num {
  width: 64rpx;
  min-width: 64rpx;
  padding: 16rpx 8rpx;
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  border-right: 1rpx solid #e8e8e8;
}

.td:last-child {
  border-right: none;
}

.more-tip {
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  color: #999;
  background: #fafafa;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

/* 使用规则弹窗 */
.notice-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #e6f4ff 0%, #f0f7ff 100%);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #bae0ff;
}

.notice-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #1677ff;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-mask.modal-show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 0 0 24rpx 24rpx;
  max-height: 70vh;
  transform: translateY(-100%);
  transition: transform 0.3s ease-out;
  z-index: 1001;
}

.modal-content.modal-slide-in {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx;
  max-height: calc(70vh - 80rpx);
  box-sizing: border-box;
}


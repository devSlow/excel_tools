<view class="container">
  <view class="banner-skeleton" wx:if="{{bannerList.length === 0}}">
    <view class="skeleton-item"></view>
  </view>
  <swiper class="banner-swiper" indicator-dots="{{bannerList.length > 1}}" autoplay="{{bannerList.length > 0}}" circular="{{bannerList.length > 2}}" interval="3000" duration="500" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#ffffff" wx:if="{{bannerList.length > 0}}">
    <swiper-item wx:for="{{bannerList}}" wx:key="id" bindtap="goToBanner" data-link="{{item.linkUrl}}" data-notice-id="{{item.noticeId}}">
      <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <view class="notice-card" bindtap="toggleNotice">
    <icon type="info" size="18" color="#1677ff" />
    <text class="notice-title">使用规则</text>
    <text class="notice-hint">点击查看</text>
  </view>

  <!-- 使用规则弹窗 -->
  <view class="modal-mask {{noticeVisible ? 'modal-show' : ''}}" bindtap="closeNotice">
    <view class="modal-content {{noticeVisible ? 'modal-slide-in' : 'modal-slide-out'}}" catchtap="">
      <view class="modal-header">
        <text class="modal-title">使用规则</text>
        <view class="modal-close" bindtap="closeNotice">
          <icon type="clear" size="14" color="#999999" />
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="notice-content">
          <text class="notice-text">1. 默认将第一行数据作为表头</text>
          <view class="notice-text-row">
            <text class="notice-text">2. 行与行之间由以下符号进行分割</text>
            <view class="delimiter-tags">
              <text class="delimiter-tag">/ 斜杠</text>
              <text class="delimiter-tag">换行</text>
            </view>
          </view>
          <view class="notice-text-row">
            <text class="notice-text">3. 列与列之间自动识别，优先级如下</text>
            <view class="delimiter-tags">
              <text class="delimiter-tag">+ 加号</text>
              <text class="delimiter-tag">, 逗号</text>
              <text class="delimiter-tag">; 分号</text>
              <text class="delimiter-tag">空格</text>
            </view>
          </view>
        </view>
        <view class="example-section">
          <text class="example-title">输入示例：</text>
          <view class="example-box">
            <text class="example-text">姓名 分数/张三 90/李四 85</text>
            <text class="example-text">姓名,分数/张三,90/李四,85</text>
            <text class="example-text">姓名+分数/张三+90/李四+85</text>
            <text class="example-text">姓名;分数/张三;90/李四;85</text>
          </view>
          <text class="example-title" style="margin-top: 16rpx;">解析结果：</text>
          <view class="example-box">
            <text class="example-text">姓名 | 分数</text>
            <text class="example-text">张三 | 90</text>
            <text class="example-text">李四 | 85</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="input-section">
    <view class="section-title">请粘贴或输入需要解析的文本</view>
    <textarea class="text-input" placeholder="在此粘贴或输入文本数据..." value="{{inputText}}" bindinput="onInputChange" maxlength="-1" />
  </view>

  <!-- <view class="delimiter-section">
    <view class="section-title">分隔符设置</view>
    <view class="delimiter-options">
      <view class="delimiter-option {{delimiter === 'auto' ? 'active' : ''}}" bindtap="selectDelimiter" data-value="auto">
        <text class="option-icon">⚡</text>
        <text class="option-text">自动识别</text>
      </view>
      <view class="delimiter-option {{delimiter === ' ' ? 'active' : ''}}" bindtap="selectDelimiter" data-value=" ">
        <text class="option-icon">␣</text>
        <text class="option-text">空格</text>
      </view>
      <view class="delimiter-option {{delimiter === '\t' ? 'active' : ''}}" bindtap="selectDelimiter" data-value="\t">
        <text class="option-icon">⇥</text>
        <text class="option-text">Tab</text>
      </view>
      <view class="delimiter-option {{delimiter === ',' ? 'active' : ''}}" bindtap="selectDelimiter" data-value=",">
        <text class="option-icon">,</text>
        <text class="option-text">逗号</text>
      </view>
      <view class="delimiter-option {{delimiter === ';' ? 'active' : ''}}" bindtap="selectDelimiter" data-value=";">
        <text class="option-icon">;</text>
        <text class="option-text">分号</text>
      </view>
    </view>
  </view> -->

  <button class="parse-btn" bindtap="handleParse" disabled="{{!inputText}}">
    开始解析
  </button>

  <view class="preview-section" wx:if="{{showResult && result.columns.length > 0}}">
    <view class="result-header">
      <view class="section-title">解析结果</view>
      <view class="result-stats">
        <view class="stat-item">
          <text class="stat-value">{{result.rowCount}}</text>
          <text class="stat-label">行</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{result.columnCount}}</text>
          <text class="stat-label">列</text>
        </view>
      </view>
    </view>
    <view class="preview-actions">
      <button class="save-btn" bindtap="saveAsTask">保存为任务</button>
    </view>
    <scroll-view class="table-wrapper" scroll-x="true" scroll-y="true">
      <view class="data-table">
        <view class="table-header">
          <view class="th row-num">#</view>
          <view class="th" wx:for="{{result.columns}}" wx:key="index">
            {{item}}
          </view>
        </view>
        <view class="table-body">
          <view class="tr" wx:for="{{result.data}}" wx:key="index" wx:for-item="row" wx:for-index="rowIdx">
            <view class="td row-num">{{rowIdx + 1}}</view>
            <view class="td" wx:for="{{row}}" wx:key="index">
              {{item}}
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="more-tip" wx:if="{{result.rowCount > 100}}">
      <text>仅显示前 100 行，更多数据请保存后查看</text>
    </view>
  </view>
</view>
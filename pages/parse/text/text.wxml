<view class="container">
  <view class="input-section">
    <view class="section-title">请粘贴或输入需要解析的文本</view>
    <textarea class="text-input" placeholder="支持空格、Tab、逗号、换行等分隔符" value="{{inputText}}" bindinput="onInputChange" auto-height maxlength="-1" />
  </view>

  <view class="delimiter-section">
    <view class="section-title">分隔符设置</view>
    <view class="delimiter-options">
      <view class="delimiter-option {{delimiter === 'auto' ? 'active' : ''}}" bindtap="selectDelimiter" data-value="auto">自动识别</view>
      <view class="delimiter-option {{delimiter === ' ' ? 'active' : ''}}" bindtap="selectDelimiter" data-value=" ">空格</view>
      <view class="delimiter-option {{delimiter === '\t' ? 'active' : ''}}" bindtap="selectDelimiter" data-value="\t">Tab</view>
      <view class="delimiter-option {{delimiter === ',' ? 'active' : ''}}" bindtap="selectDelimiter" data-value=",">逗号</view>
      <view class="delimiter-option {{delimiter === ';' ? 'active' : ''}}" bindtap="selectDelimiter" data-value=";">分号</view>
    </view>
  </view>

  <view class="btn-row">
    <button class="parse-btn" bindtap="handleParse" disabled="{{!inputText}}">
      开始解析
    </button>
  </view>

  <view class="preview-section" wx:if="{{showResult && result.columns.length > 0}}">
    <view class="section-header">
      <view class="section-title">解析结果</view>
    </view>
    <view class="result-stats">
      <view class="stat-item">
        <text class="stat-value">{{result.rowCount}}</text>
        <text class="stat-label">数据行数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{result.columnCount}}</text>
        <text class="stat-label">列数</text>
      </view>
    </view>
    <view class="preview-actions">
      <button class="action-btn" bindtap="saveAsTask">保存为任务</button>
    </view>
    <scroll-view class="table-wrapper" scroll-x="true" scroll-y="true">
      <view class="data-table">
        <view class="table-header">
          <view class="th" style="min-width: 70rpx; width: 70rpx; background: #595959;">#</view>
          <view class="th" wx:for="{{result.columns}}" wx:key="index" style="min-width: 120rpx; flex: 1;">
            {{item}}
          </view>
        </view>
        <view class="table-body">
          <view class="tr" wx:for="{{result.data}}" wx:key="index" wx:for-item="row" wx:for-index="rowIdx">
            <view class="row-index">{{rowIdx + 1}}</view>
            <view class="td" wx:for="{{row}}" wx:key="index" style="min-width: 120rpx; flex: 1;">
              {{item}}
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="more-tip" wx:if="{{result.rowCount > 100}}">
      <text>仅显示前 100 行，更多数据请保存后查看</text>
    </view>
  </view>
</view>
page {
  background: #f5f7fa;
  height: 100%;
}

.container {
  min-height: 100%;
  background: #f5f7fa;
  padding: 32rpx;
  box-sizing: border-box;
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx dashed #d9d9d9;
}

.upload-area:active {
  border-color: #1677ff;
  background: #fafafa;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.file-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.file-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.file-item:last-child {
  border-bottom: none;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.file-size {
  font-size: 24rpx;
  color: #999;
}

.file-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.file-status.pending { background: #f5f5f5; color: #999; }
.file-status.success { background: #f6ffed; color: #52c41a; }
.file-status.error { background: #fff2f0; color: #ff4d4f; }

.upload-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
}

.upload-btn::after {
  border: none;
}

.upload-btn[disabled] {
  opacity: 0.6;
}

.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.result-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1677ff;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.sheet-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.sheet-tab {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  transition: all 0.2s;
}

.sheet-tab.active {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.table-wrapper {
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
  max-height: 600rpx;
}

.data-table {
  display: flex;
  min-width: max-content;
  border-collapse: collapse;
}

.table-header {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 10;
}

.th {
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-right: 1rpx solid rgba(255,255,255,0.3);
  min-width: 160rpx;
  flex: 1;
}

.th:last-child {
  border-right: none;
}

.table-body {
  display: flex;
  flex-direction: column;
}

.table-body .tr {
  display: flex;
  min-width: max-content;
  transition: background 0.2s;
}

.table-body .tr:nth-child(even) {
  background: #fafafa;
}

.table-body .tr:nth-child(odd) {
  background: #fff;
}

.table-body .tr:active {
  background: #e6f4ff;
}

.row-index {
  width: 80rpx;
  min-width: 80rpx;
  padding: 16rpx 8rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  background: #f5f5f5;
  border-right: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.td {
  padding: 16rpx 12rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 160rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.td:last-child {
  border-right: none;
}

.preview-actions {
  margin-top: 24rpx;
}

.preview-actions .action-btn {
  width: 100%;
  height: 80rpx;
  background: #1677ff;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}
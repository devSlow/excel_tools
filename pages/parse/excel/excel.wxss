.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 32rpx;
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx dashed #d9d9d9;
}

.upload-area:active {
  border-color: #667eea;
  background: #fafafa;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.file-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.file-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.file-item:last-child {
  border-bottom: none;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.file-size {
  font-size: 24rpx;
  color: #999;
}

.file-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.file-status.pending { background: #f5f5f5; color: #999; }
.file-status.success { background: #f6ffed; color: #52c41a; }
.file-status.error { background: #fff2f0; color: #ff4d4f; }

.upload-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.upload-btn::after {
  border: none;
}

.upload-btn[disabled] {
  opacity: 0.6;
}

.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.sheet-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.sheet-tab {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.sheet-tab.active {
  background: #667eea;
  color: #fff;
}

.table-wrapper {
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.data-table {
  min-width: 100%;
  display: inline-block;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx 8rpx 0 0;
}

.th {
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  background: #f5f5f5;
  border-right: 1rpx solid #e0e0e0;
}

.table-body .tr {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-body .tr:last-child {
  border-bottom: none;
}

.td {
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-actions {
  margin-top: 24rpx;
}

.preview-actions .action-btn {
  width: 100%;
  height: 80rpx;
  background: #667eea;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}
<view class="container">
  <view class="header-section">
    <view class="header-icon" style="background: linear-gradient(135deg, #96fbc4 0%, #f9f586 100%);">
      <text class="header-icon-text">截</text>
    </view>
    <view class="header-info">
      <view class="header-title">网页截图</view>
      <view class="header-desc">将网页截图保存为图片</view>
    </view>
  </view>

  <view class="notice-card" bindtap="toggleNotice">
    <view class="notice-icon">!</view>
    <text class="notice-text">使用说明</text>
    <text class="notice-hint">点击查看</text>
  </view>

  <view class="modal-mask {{noticeVisible ? 'modal-show' : ''}}" bindtap="closeNotice">
    <view class="modal-content {{noticeVisible ? 'modal-slide-in' : 'modal-slide-out'}}" catchtap="">
      <view class="modal-header">
        <text class="modal-title">网页截图 使用说明</text>
        <view class="modal-close" catchtap="closeNotice">
          <icon type="clear" size="14" color="#999999" />
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="notice-section">
          <view class="notice-label">功能说明</view>
          <text class="notice-content">将网页截图保存为PNG、JPEG或WebP格式的图片</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">操作步骤</view>
          <text class="notice-content">1. 输入要截图的网页URL</text>
          <text class="notice-content">2. 选择图片格式（PNG/JPEG/WebP）</text>
          <text class="notice-content">3. 点击"开始截图"按钮</text>
          <text class="notice-content">4. 截图完成后自动保存到相册</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">注意事项</view>
          <text class="notice-content">• 请输入完整的URL地址</text>
          <text class="notice-content">• 截图需要用户授权保存到相册</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="config-section">
    <view class="config-title">输入网页地址</view>
    <view class="input-wrapper">
      <input class="url-input" placeholder="请输入完整URL，如: https://www.example.com" value="{{url}}" bindinput="onUrlInput" />
    </view>

    <view class="config-title" style="margin-top: 30rpx;">图片格式</view>
    <view class="format-options">
      <view class="format-item {{format === 'png' ? 'active' : ''}}" bindtap="selectFormat" data-format="png">
        <text class="format-name">PNG</text>
      </view>
      <view class="format-item {{format === 'jpeg' ? 'active' : ''}}" bindtap="selectFormat" data-format="jpeg">
        <text class="format-name">JPEG</text>
      </view>
      <view class="format-item {{format === 'webp' ? 'active' : ''}}" bindtap="selectFormat" data-format="webp">
        <text class="format-name">WebP</text>
      </view>
    </view>
  </view>

  <view class="action-section">
    <button class="convert-btn" bindtap="handleScreenshot" disabled="{{!url || loading}}">
      {{loading ? '截图 中...' : '开始截图'}}
    </button>
  </view>
</view>
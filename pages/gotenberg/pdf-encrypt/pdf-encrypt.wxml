<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">PDF加密</view>
    <view class="page-desc">为PDF文件添加密码保护</view>
  </view>

  <!-- 使用说明 -->
  <view class="notice-card" bindtap="toggleNotice">
    <view class="notice-icon">
      <text class="notice-icon-text">?</text>
    </view>
    <text class="notice-text">使用说明</text>
    <text class="notice-hint">点击查看</text>
  </view>

  <!-- 说明弹窗 -->
  <view class="modal-mask {{noticeVisible ? 'modal-show' : ''}}" bindtap="closeNotice">
    <view class="modal-content {{noticeVisible ? 'modal-slide-in' : 'modal-slide-out'}}" catchtap="">
      <view class="modal-header">
        <text class="modal-title">使用说明</text>
        <view class="modal-close" catchtap="closeNotice">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="notice-section">
          <view class="notice-label">功能说明</view>
          <text class="notice-content">为PDF文件设置打开密码，保护您的文档安全</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">密码类型</view>
          <text class="notice-content">• 用户密码：打开PDF时需要输入的密码</text>
          <text class="notice-content">• 所有者密码：可设置文件权限的密码（可选）</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">操作步骤</view>
          <text class="notice-content">1. 选择要加密的PDF文件</text>
          <text class="notice-content">2. 输入用户密码（必填）</text>
          <text class="notice-content">3. 输入所有者密码（可选）</text>
          <text class="notice-content">4. 点击"开始加密"按钮</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 文件上传 -->
  <view class="upload-section">
    <view class="upload-area {{selectedFile ? 'has-file' : ''}}" bindtap="chooseFile">
      <view class="upload-icon" wx:if="{{!selectedFile}}">
        <text class="upload-icon-text">+</text>
      </view>
      <view class="upload-hint" wx:if="{{!selectedFile}}">点击选择PDF文件</view>
      <view class="file-info" wx:else>
        <view class="file-name">{{selectedFile}}</view>
      </view>
      <view class="upload-clear" catchtap="clearFile" wx:if="{{selectedFile}}">清除</view>
    </view>
  </view>

  <!-- 加密设置 -->
  <view class="config-section">
    <view class="config-title">加密设置</view>
    <view class="config-item">
      <view class="config-label">
        <text class="required">*</text>
        用户密码
      </view>
      <input class="config-input" placeholder="必填，打开文件需要此密码" password="{{true}}" value="{{userPassword}}" bindinput="onUserPasswordInput" />
    </view>
    <view class="config-item">
      <view class="config-label">所有者密码</view>
      <input class="config-input" placeholder="可选，用于设置权限" password="{{true}}" value="{{ownerPassword}}" bindinput="onOwnerPasswordInput" />
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="submit-btn" bindtap="handleEncrypt" disabled="{{!selectedFile || !userPassword || loading}}">
      {{loading ? '加密中...' : '开始加密'}}
    </button>
  </view>
</view>

<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">PDF拆分</view>
    <view class="page-desc">将PDF文件拆分为多个文件</view>
  </view>

  <!-- 使用说明 -->
  <view class="notice-card" bindtap="toggleNotice">
    <view class="notice-icon">
      <text class="notice-icon-text">?</text>
    </view>
    <text class="notice-text">使用说明</text>
    <text class="notice-hint">点击查看</text>
  </view>

  <!-- 说明弹窗 -->
  <view class="modal-mask {{noticeVisible ? 'modal-show' : ''}}" bindtap="closeNotice">
    <view class="modal-content {{noticeVisible ? 'modal-slide-in' : 'modal-slide-out'}}" catchtap="">
      <view class="modal-header">
        <text class="modal-title">使用说明</text>
        <view class="modal-close" catchtap="closeNotice">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="notice-section">
          <view class="notice-label">功能说明</view>
          <text class="notice-content">将一个PDF文件拆分为多个独立的PDF文件</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">拆分模式</view>
          <text class="notice-content">• 按间隔：每N页生成一个文件</text>
          <text class="notice-content">• 按单页：每页生成一个独立文件</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">操作步骤</view>
          <text class="notice-content">1. 选择要拆分的PDF文件</text>
          <text class="notice-content">2. 选择拆分模式</text>
          <text class="notice-content">3. 输入拆分参数</text>
          <text class="notice-content">4. 点击"开始拆分"按钮</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 文件上传 -->
  <view class="upload-section">
    <view class="upload-area {{selectedFile ? 'has-file' : ''}}" bindtap="chooseFile">
      <view class="upload-icon" wx:if="{{!selectedFile}}">
        <text class="upload-icon-text">+</text>
      </view>
      <view class="upload-hint" wx:if="{{!selectedFile}}">点击选择PDF文件</view>
      <view class="file-info" wx:else>
        <view class="file-name">{{selectedFile}}</view>
      </view>
      <view class="upload-clear" catchtap="clearFile" wx:if="{{selectedFile}}">清除</view>
    </view>
  </view>

  <!-- 拆分设置 -->
  <view class="config-section">
    <view class="config-title">拆分模式</view>
    <view class="mode-grid">
      <view class="mode-item {{splitMode === 'intervals' ? 'active' : ''}}" bindtap="selectMode" data-mode="intervals">
        <view class="mode-name">按间隔</view>
        <view class="mode-desc">每N页生成一个文件</view>
      </view>
      <view class="mode-item {{splitMode === 'pages' ? 'active' : ''}}" bindtap="selectMode" data-mode="pages">
        <view class="mode-name">按单页</view>
        <view class="mode-desc">每页生成独立文件</view>
      </view>
    </view>

    <view class="config-item" wx:if="{{splitMode === 'intervals'}}">
      <view class="config-label">每</view>
      <input class="config-input-small" type="number" value="{{splitSpan}}" bindinput="onSpanInput" />
      <view class="config-label">页生成一个文件</view>
    </view>

    <view class="config-item" wx:if="{{splitMode === 'pages'}}">
      <view class="config-label">页码范围</view>
      <input class="config-input" placeholder="如: 2- 或 1,3,5" value="{{splitSpan}}" bindinput="onSpanInput" />
      <view class="config-hint">留空表示所有页面，格式：2-（第2页到最后）、1,3,5（指定页码）</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="submit-btn" bindtap="handleSplit" disabled="{{!selectedFile || loading}}">
      {{loading ? '拆分中...' : '开始拆分'}}
    </button>
  </view>

  <!-- 拆分结果 -->
  <view class="result-section" wx:if="{{splitFiles.length > 0}}">
    <view class="result-title">拆分结果 ({{splitFiles.length}}个文件)</view>
    <view class="result-list">
      <view class="result-item" wx:for="{{splitFiles}}" wx:key="index" bindtap="openFile" data-index="{{index}}">
        <view class="result-icon">
          <text class="result-icon-text">PDF</text>
        </view>
        <view class="result-info">
          <view class="result-name">{{item.name}}</view>
          <view class="result-hint">点击打开</view>
        </view>
        <view class="result-arrow">›</view>
      </view>
    </view>
  </view>
</view>

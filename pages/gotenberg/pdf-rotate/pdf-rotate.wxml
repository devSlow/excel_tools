<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">PDF旋转</view>
    <view class="page-desc">旋转PDF页面角度</view>
  </view>

  <!-- 使用说明 -->
  <view class="notice-card" bindtap="toggleNotice">
    <view class="notice-icon">
      <text class="notice-icon-text">?</text>
    </view>
    <text class="notice-text">使用说明</text>
    <text class="notice-hint">点击查看</text>
  </view>

  <!-- 说明弹窗 -->
  <view class="modal-mask {{noticeVisible ? 'modal-show' : ''}}" bindtap="closeNotice">
    <view class="modal-content {{noticeVisible ? 'modal-slide-in' : 'modal-slide-out'}}" catchtap="">
      <view class="modal-header">
        <text class="modal-title">使用说明</text>
        <view class="modal-close" catchtap="closeNotice">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="notice-section">
          <view class="notice-label">功能说明</view>
          <text class="notice-content">将PDF页面按顺时针旋转90°、180°或270°</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">操作步骤</view>
          <text class="notice-content">1. 选择要旋转的PDF文件</text>
          <text class="notice-content">2. 选择旋转角度</text>
          <text class="notice-content">3. 可选择旋转特定页面或全部页面</text>
          <text class="notice-content">4. 点击"开始旋转"按钮</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 文件上传 -->
  <view class="upload-section">
    <view class="upload-area {{selectedFile ? 'has-file' : ''}}" bindtap="chooseFile">
      <view class="upload-icon" wx:if="{{!selectedFile}}">
        <text class="upload-icon-text">+</text>
      </view>
      <view class="upload-hint" wx:if="{{!selectedFile}}">点击选择PDF文件</view>
      <view class="file-info" wx:else>
        <view class="file-name">{{selectedFile}}</view>
      </view>
      <view class="upload-clear" catchtap="clearFile" wx:if="{{selectedFile}}">清除</view>
    </view>
  </view>

  <!-- 旋转设置 -->
  <view class="config-section">
    <view class="config-title">旋转角度</view>
    <view class="angle-grid">
      <view class="angle-item {{angle === 90 ? 'active' : ''}}" bindtap="selectAngle" data-angle="90">
        <view class="angle-num">90°</view>
        <view class="angle-desc">顺时针</view>
      </view>
      <view class="angle-item {{angle === 180 ? 'active' : ''}}" bindtap="selectAngle" data-angle="180">
        <view class="angle-num">180°</view>
        <view class="angle-desc">倒置</view>
      </view>
      <view class="angle-item {{angle === 270 ? 'active' : ''}}" bindtap="selectAngle" data-angle="270">
        <view class="angle-num">270°</view>
        <view class="angle-desc">逆时针</view>
      </view>
    </view>

    <view class="config-item">
      <view class="config-label">页码范围（可选）</view>
      <input class="config-input" placeholder="如: 1-3,5,7-10" value="{{pages}}" bindinput="onPagesInput" />
    </view>
    <view class="config-hint">留空表示旋转所有页面</view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="submit-btn" bindtap="handleRotate" disabled="{{!selectedFile || loading}}">
      {{loading ? '旋转中...' : '开始旋转'}}
    </button>
  </view>
</view>

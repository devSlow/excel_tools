page {
  background: linear-gradient(180deg, #f0f2f8 0%, #f5f7fa 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header-section {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.header-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.header-icon-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: #999;
}

.notice-card {
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.notice-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #667eea;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

.notice-hint {
  font-size: 22rpx;
  color: #667eea;
  opacity: 0.7;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  pointer-events: none;
  transition: background 0.3s;
}

.modal-mask.modal-show {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal-mask.modal-show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  padding: 8rpx;
}

.modal-body {
  max-height: calc(80vh - 100rpx);
  padding: 24rpx 32rpx 60rpx;
}

.notice-section {
  margin-bottom: 28rpx;
}

.notice-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.notice-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-area {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 3rpx dashed #e0e0e0;
  position: relative;
  transition: all 0.3s ease;
}

.upload-area.has-file {
  border-color: #667eea;
  background: #f8f9ff;
  padding: 40rpx 32rpx;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.upload-icon-text {
  font-size: 60rpx;
  font-weight: 300;
  color: #fff;
}

.upload-hint {
  font-size: 28rpx;
  color: #999;
}

.file-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.file-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  text-align: center;
  word-break: break-all;
}

.file-type {
  font-size: 24rpx;
  color: #667eea;
  background: #f0f4ff;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.upload-clear {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 24rpx;
  background: #667eea;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.format-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #667eea;
}

.format-grid {
  display: flex;
  gap: 16rpx;
}

.format-item {
  flex: 1;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.format-item:active {
  transform: scale(0.95);
}

.format-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
}

.format-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #667eea;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.format-item.active .format-icon {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.format-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.format-item.active .format-name {
  color: #fff;
  font-weight: 600;
}

.action-section {
  margin-top: auto;
  padding-top: 24rpx;
}

.convert-btn {
  width: 100%;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.35);
  border: none;
  letter-spacing: 2rpx;
}

.convert-btn::after {
  border: none;
}

.convert-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}

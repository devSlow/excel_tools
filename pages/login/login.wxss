.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.login-logo text {
  font-size: 80rpx;
  color: #fff;
}

.login-title {
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 80rpx;
}

.login-btn {
  width: 600rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #667eea;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.login-btn::after {
  border: none;
}

.login-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.login-tips {
  position: absolute;
  bottom: 60rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
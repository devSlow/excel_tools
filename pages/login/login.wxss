.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1677ff 0%, #0958d9 100%);
  display: flex;
  flex-direction: column;
  padding: 120rpx 60rpx 60rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.logo-icon {
  font-size: 80rpx;
}

.login-title {
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.6;
}

.login-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-list {
  width: 100%;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 60rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.feature-item:not(:last-child) {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #fff;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.25);
  border: none;
  padding: 0;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 1;
}

.login-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  background: #07c160;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.wechat-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.btn-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
}

.login-btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.spinner {
  width: 44rpx;
  height: 44rpx;
  border: 5rpx solid rgba(22, 119, 255, 0.2);
  border-top-color: #1677ff;
  border-right-color: #1677ff;
  border-bottom-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

.loading-text {
  font-size: 32rpx;
  color: #1677ff;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.login-hint {
  margin-top: 32rpx;
  text-align: center;
}

.hint-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.loading-hint .hint-text {
  color: rgba(255, 255, 255, 0.6);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.login-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.link-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin: 0 4rpx;
}

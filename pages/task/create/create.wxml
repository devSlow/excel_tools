<view class="container">
  <view class="form-group">
    <view class="form-label">任务名称</view>
    <input class="form-input" placeholder="请输入任务名称" value="{{taskName}}" bindinput="onTaskNameInput" maxlength="50" />
  </view>

  <view class="form-group">
    <view class="form-label">任务描述</view>
    <textarea class="form-textarea" placeholder="请输入任务描述（选填）" value="{{taskDesc}}" bindinput="onTaskDescInput" maxlength="200" />
  </view>

  <view class="form-group">
    <view class="form-label">数据来源</view>
    <view class="source-options">
      <view class="source-option {{source === 'text' ? 'active' : ''}}" bindtap="selectSource" data-source="text">
        <icon type="waiting" size="18" color="#1677ff" />
        <text class="option-text">文本解析</text>
      </view>
      <view class="source-option {{source === 'excel' ? 'active' : ''}}" bindtap="selectSource" data-source="excel">
        <icon type="info" size="18" color="#1677ff" />
        <text class="option-text">Excel导入</text>
      </view>
    </view>
  </view>

  <view class="btn-group">
    <button class="btn btn-primary" bindtap="handleSubmit" disabled="{{!taskName || loading}}">
      {{loading ? '创建中...' : '创建任务'}}
    </button>
    <button class="btn btn-default" bindtap="handleCancel">取消</button>
  </view>
</view>
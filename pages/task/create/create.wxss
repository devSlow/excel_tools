.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 32rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  font-size: 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.source-options {
  display: flex;
  gap: 24rpx;
}

.source-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.source-option.active {
  background: #f0f7ff;
  border-color: #1677ff;
}

.option-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.option-text {
  font-size: 28rpx;
  color: #666;
}

.source-option.active .option-text {
  color: #1677ff;
  font-weight: 500;
}

.btn-group {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
}

.btn-default {
  background: #fff;
  color: #666;
  border: 2rpx solid #d9d9d9;
}

.btn-primary[disabled] {
  opacity: 0.6;
}
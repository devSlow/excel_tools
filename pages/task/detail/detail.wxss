.container {
  min-height: 100%;
  background: #f5f7fa;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.task-header {
  background: #fff;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.task-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.task-status.completed { background: #e6f7ff; color: #1890ff; }
.task-status.processing { background: #fff7e6; color: #fa8c16; }
.task-status.draft { background: #f5f5f5; color: #999; }

.task-desc {
  background: #fff;
  padding: 0 32rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.info-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.table-wrapper {
  overflow: auto;
  -webkit-overflow-scrolling: touch;
}

.data-table {
  min-width: 100%;
  display: inline-block;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx 8rpx 0 0;
}

.th {
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  background: #f5f5f5;
  border-right: 1rpx solid #e0e0e0;
}

.table-body .tr {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-body .tr:last-child {
  border-bottom: none;
}

.td {
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  padding: 20rpx 0;
  background: transparent;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.delete {
  color: #ff4d4f;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal.show {
  display: flex;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 600rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.field-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.field-item {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.field-item.active {
  background: #1677ff;
  color: #fff;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-actions .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.modal-actions .btn-primary {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
}

.modal-actions .btn-default {
  background: #f5f5f5;
  color: #666;
}

.btn::after {
  border: none;
}
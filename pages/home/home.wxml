<view class="container">
  <!-- 顶部问候 -->
  <view class="header">
    <view class="greeting">
      <view class="greeting-text">您好</view>
      <view class="greeting-date">{{currentDate}}</view>
    </view>
    <view class="header-badge">Beta</view>
  </view>

  <!-- 任务统计（已登录） -->
  <view class="stats-card" wx:if="{{isLoggedIn}}" bindtap="goToTaskList">
    <view class="stats-left">
      <view class="stats-num">{{totalTasks}}</view>
      <view class="stats-label">个任务</view>
    </view>
    <view class="stats-right">
      <text class="stats-link">查看全部</text>
      <text class="stats-arrow">›</text>
    </view>
  </view>

  <!-- 文档处理 -->
  <view class="section">
    <view class="section-title">文档处理</view>
    <view class="func-grid">
      <view class="func-card" bindtap="goToService" data-type="text">
        <view class="func-icon func-icon-blue">
          <view class="icon-inner">T</view>
        </view>
        <view class="func-name">文本转Excel</view>
      </view>
      
      <view class="func-card" bindtap="goToService" data-type="doc-convert">
        <view class="func-icon func-icon-purple">
          <view class="icon-inner">C</view>
        </view>
        <view class="func-name">文档转换</view>
      </view>

      <view class="func-card" bindtap="goToService" data-type="pdf-parse">
        <view class="func-icon func-icon-green">
          <view class="icon-inner">E</view>
        </view>
        <view class="func-name">文档解析</view>
      </view>
    </view>
  </view>

  <!-- PDF工具 -->
  <view class="section">
    <view class="section-title">PDF工具</view>
    <view class="func-grid">
      <view class="func-card" bindtap="goToService" data-type="pdf-merge">
        <view class="func-icon func-icon-teal">
          <view class="icon-inner">M</view>
        </view>
        <view class="func-name">合并</view>
      </view>

      <view class="func-card" bindtap="goToService" data-type="pdf-split">
        <view class="func-icon func-icon-orange">
          <view class="icon-inner">S</view>
        </view>
        <view class="func-name">拆分</view>
      </view>

      <view class="func-card" bindtap="goToService" data-type="pdf-rotate">
        <view class="func-icon func-icon-pink">
          <view class="icon-inner">R</view>
        </view>
        <view class="func-name">旋转</view>
      </view>

      <view class="func-card" bindtap="goToService" data-type="pdf-encrypt">
        <view class="func-icon func-icon-red">
          <view class="icon-inner">L</view>
        </view>
        <view class="func-name">加密</view>
      </view>

      <view class="func-card" bindtap="goToService" data-type="pdf-watermark">
        <view class="func-icon func-icon-indigo">
          <view class="icon-inner">W</view>
        </view>
        <view class="func-name">水印</view>
      </view>
    </view>
  </view>

  <!-- 最近任务（已登录） -->
  <view class="section" wx:if="{{isLoggedIn}}">
    <view class="section-header">
      <view class="section-title">最近任务</view>
      <view class="section-more" bindtap="goToTaskList" wx:if="{{recentTasks.length > 0}}">更多</view>
    </view>
    <view class="task-list" wx:if="{{recentTasks.length > 0}}">
      <view class="task-item" wx:for="{{recentTasks}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="task-info">
          <view class="task-name">{{item.name}}</view>
          <view class="task-meta">
            <text class="task-count">{{item.rowCount}}条数据</text>
            <text class="task-time">{{item.createTime}}</text>
          </view>
        </view>
        <view class="task-status {{item.status}}">{{item.statusText}}</view>
      </view>
    </view>
    <view class="empty-task" wx:if="{{recentTasks.length === 0}}">
      <view class="empty-text">暂无任务记录</view>
    </view>
  </view>
</view>

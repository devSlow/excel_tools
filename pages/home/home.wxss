page {
  background: linear-gradient(180deg, #f0f2f8 0%, #f5f7fa 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.hero-section {
  position: relative;
  margin: 0 -32rpx;
  padding: 48rpx 32rpx 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-content {
  flex: 1;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.hero-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.hero-wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 32rpx;
  background: #f5f7fa;
  border-radius: 50% 50% 0 0;
}

.tools-section {
  margin-top: -16rpx;
  position: relative;
  z-index: 2;
  padding-bottom: 24rpx;
}

.tools-grid {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.tool-card {
  width: 300rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s ease;
  border: 3rpx solid transparent;
}

.tool-card.active {
  border-color: #667eea;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.2);
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.tool-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.tool-count {
  font-size: 22rpx;
  color: #999;
}

.tools-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.tab-content {
  display: none;
}

.tab-content.show {
  display: block;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #667eea;
}

.sub-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sub-card {
  display: flex;
  align-items: center;
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  transition: all 0.2s ease;
}

.sub-card:active {
  background: #f0f2f8;
  transform: scale(0.98);
}

.sub-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.sub-icon-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.sub-info {
  flex: 1;
}

.sub-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.sub-desc {
  font-size: 24rpx;
  color: #999;
}

.sub-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

.bottom-section {
  padding-bottom: 40rpx;
}

.capabilities-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.capabilities-header {
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding-left: 8rpx;
  border-left: 4rpx solid #667eea;
}

.capabilities-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.capability-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.capability-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.capability-icon text {
  font-size: 26rpx;
  font-weight: 700;
}

.capability-name {
  font-size: 22rpx;
  color: #666;
}

.formats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.formats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.format-tag {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #f0f2f8 0%, #e8ecf4 100%);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}
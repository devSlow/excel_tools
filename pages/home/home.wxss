page {
  background: #f5f7fa;
  height: 100vh;
  overflow: hidden;
}

.container {
  height: 100vh;
  padding: 0 32rpx;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.hero-section {
  position: relative;
  margin: 0 -32rpx;
  padding: 60rpx 32rpx 90rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

.hero-wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #f5f7fa;
  border-radius: 50% 50% 0 0;
}

.tools-section {
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.tool-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.tool-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tool-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-font {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #999;
}

.bottom-section {
  margin-top: 32rpx;
}

.features-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.feature-icon text {
  font-size: 28rpx;
  font-weight: 700;
}

.feature-name {
  font-size: 22rpx;
  color: #666;
}

.formats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.formats-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.format-tag {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf0 100%);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
}
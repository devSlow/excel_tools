page {
  background: #F8FAFC;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
  padding-top: 16rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
}

.greeting-date {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.header-badge {
  background: #EFF6FF;
  color: #3B82F6;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* Stats Card */
.stats-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.stats-left {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.stats-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.stats-label {
  font-size: 26rpx;
  color: #94A3B8;
}

.stats-right {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stats-link {
  font-size: 26rpx;
  color: #3B82F6;
}

.stats-arrow {
  font-size: 28rpx;
  color: #3B82F6;
}

/* Section */
.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #3B82F6;
}

/* Function Grid - 3 columns */
.func-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.func-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  text-align: center;
  transition: all 0.2s ease;
}

.func-card:active {
  transform: scale(0.96);
}

.func-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 14rpx;
}

.func-icon-blue {
  background: #EFF6FF;
}

.func-icon-purple {
  background: #F3E8FF;
}

.func-icon-green {
  background: #F0FDF4;
}

.func-icon-teal {
  background: #F0FDFA;
}

.func-icon-orange {
  background: #FFF7ED;
}

.func-icon-pink {
  background: #FDF2F8;
}

.func-icon-red {
  background: #FEF2F2;
}

.func-icon-indigo {
  background: #EEF2FF;
}

.icon-inner {
  font-size: 26rpx;
  font-weight: 700;
}

.func-icon-blue .icon-inner {
  color: #3B82F6;
}

.func-icon-purple .icon-inner {
  color: #8B5CF6;
}

.func-icon-green .icon-inner {
  color: #22C55E;
}

.func-icon-teal .icon-inner {
  color: #14B8A6;
}

.func-icon-orange .icon-inner {
  color: #F97316;
}

.func-icon-pink .icon-inner {
  color: #EC4899;
}

.func-icon-red .icon-inner {
  color: #EF4444;
}

.func-icon-indigo .icon-inner {
  color: #6366F1;
}

.func-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1E293B;
}

/* Task List */
.task-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  transition: background 0.2s;
}

.task-item:active {
  background: #F8FAFC;
}

.task-item:not(:last-child) {
  border-bottom: 1rpx solid #F1F5F9;
}

.task-info {
  flex: 1;
  margin-right: 16rpx;
}

.task-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1E293B;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-count,
.task-time {
  font-size: 22rpx;
  color: #94A3B8;
}

.task-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  white-space: nowrap;
}

.task-status.completed {
  background: #F0FDFA;
  color: #14B8A6;
}

.task-status.processing {
  background: #FFF7ED;
  color: #F97316;
}

.task-status.draft {
  background: #F1F5F9;
  color: #94A3B8;
}

/* Empty Task */
.empty-task {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

page {
  background: #f5f7fa;
  min-height: 100%;
}

.container {
  min-height: 100%;
  padding: 32rpx;
  box-sizing: border-box;
}

.header-section {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.header-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.header-icon-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: #999;
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-area {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 2rpx dashed #e0e0e0;
  position: relative;
}

.upload-area.has-file {
  border-color: #43e97b;
  background: #f0fff4;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.upload-icon-text {
  font-size: 60rpx;
  font-weight: 300;
  color: #fff;
}

.upload-hint {
  font-size: 28rpx;
  color: #999;
}

.file-count {
  font-size: 28rpx;
  color: #43e97b;
  font-weight: 600;
}

.upload-clear {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 24rpx;
  background: #43e97b;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.file-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.file-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.file-item:last-child {
  border-bottom: none;
}

.file-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-remove {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.config-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.config-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-item:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 26rpx;
  color: #666;
}

.picker-value {
  font-size: 26rpx;
  color: #333;
  padding: 8rpx 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.action-section {
  margin-bottom: 24rpx;
}

.convert-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(67, 233, 123, 0.3);
  border: none;
}

.progress-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.progress-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.result-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.result-count {
  font-size: 24rpx;
  color: #43e97b;
  padding: 8rpx 20rpx;
  background: #f0fff4;
  border-radius: 16rpx;
}

.result-list {
  margin-bottom: 20rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  margin-left: 16rpx;
}

.result-status.success {
  background: #f0fff4;
  color: #43e97b;
}

.result-status.error {
  background: #fff1f0;
  color: #ff4d4f;
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx 0;
  font-size: 26rpx;
  border-radius: 20rpx;
  border: none;
}

.export-btn {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: #fff;
}

.notice-card {
  background: linear-gradient(135deg, #f0fff4 0%, #e0fff0 100%);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.notice-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #43e97b;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #2e9e6a;
  font-weight: 500;
}

.notice-hint {
  font-size: 22rpx;
  color: #43e97b;
  opacity: 0.7;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  pointer-events: none;
  transition: background 0.3s;
}

.modal-mask.modal-show {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal-mask.modal-show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  padding: 8rpx;
}

.modal-body {
  max-height: calc(80vh - 100rpx);
  padding: 24rpx 32rpx 60rpx;
}

.notice-section {
  margin-bottom: 28rpx;
}

.notice-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.notice-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}
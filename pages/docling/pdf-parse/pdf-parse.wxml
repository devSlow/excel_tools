<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">文档解析</view>
    <view class="page-desc">支持PDF、Word、图片等多种格式</view>
  </view>

  <!-- 使用说明 -->
  <view class="notice-card" bindtap="toggleNotice">
    <view class="notice-icon">
      <text class="notice-icon-text">?</text>
    </view>
    <text class="notice-text">使用说明</text>
    <text class="notice-hint">点击查看</text>
  </view>

  <!-- 说明弹窗 -->
  <view class="modal-mask {{noticeVisible ? 'modal-show' : ''}}" bindtap="closeNotice">
    <view class="modal-content {{noticeVisible ? 'modal-slide-in' : 'modal-slide-out'}}" catchtap="">
      <view class="modal-header">
        <text class="modal-title">使用说明</text>
        <view class="modal-close" catchtap="closeNotice">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="notice-section">
          <view class="notice-label">支持格式</view>
          <text class="notice-content">PDF、Word(.doc/.docx)、Excel(.xls/.xlsx)、图片、PPT、TXT等文档格式</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">输出格式</view>
          <text class="notice-content">• Markdown - 保留排版结构的富文本格式</text>
          <text class="notice-content">• JSON - 结构化数据，便于程序处理</text>
          <text class="notice-content">• Text - 纯文本，提取所有文字内容</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">OCR识别</view>
          <text class="notice-content">启用后可识别图片中的文字，适用于扫描件或截图</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">表格结构识别</view>
          <text class="notice-content">启用后可精准还原文档中的表格结构</text>
        </view>
        <view class="notice-section">
          <view class="notice-label">操作步骤</view>
          <text class="notice-content">1. 点击选择文件上传文档</text>
          <text class="notice-content">2. 选择需要的输出格式</text>
          <text class="notice-content">3. 根据需要开启OCR和表格识别</text>
          <text class="notice-content">4. 点击"开始解析"按钮</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 文件上传 -->
  <view class="upload-section">
    <view class="upload-area {{selectedFile ? 'has-file' : ''}}" bindtap="chooseFile">
      <view class="upload-icon" wx:if="{{!selectedFile}}">
        <text class="upload-icon-text">+</text>
      </view>
      <view class="upload-hint" wx:if="{{!selectedFile}}">点击选择文档文件</view>
      <view class="file-info" wx:else>
        <view class="file-name">{{selectedFile}}</view>
      </view>
      <view class="upload-clear" catchtap="clearFile" wx:if="{{selectedFile}}">清除</view>
    </view>
  </view>

  <!-- 输出格式 -->
  <view class="config-section">
    <view class="config-title">输出格式</view>
    <view class="format-grid">
      <view class="format-item {{selectedOutputFormat === 'markdown' ? 'active' : ''}}" bindtap="selectFormat" data-format="markdown">
        <view class="format-name">Markdown</view>
      </view>
      <view class="format-item {{selectedOutputFormat === 'json' ? 'active' : ''}}" bindtap="selectFormat" data-format="json">
        <view class="format-name">JSON</view>
      </view>
      <view class="format-item {{selectedOutputFormat === 'text' ? 'active' : ''}}" bindtap="selectFormat" data-format="text">
        <view class="format-name">Text</view>
      </view>
    </view>
  </view>

  <!-- OCR设置 -->
  <view class="config-section">
    <view class="config-title">高级设置</view>
    <view class="switch-item">
      <view class="switch-info">
        <view class="switch-label">启用OCR</view>
        <view class="switch-desc">识别图片中的文字</view>
      </view>
      <switch checked="{{enableOcr}}" bindchange="onOcrChange" color="#3B82F6"/>
    </view>
    <view class="switch-item">
      <view class="switch-info">
        <view class="switch-label">表格结构识别</view>
        <view class="switch-desc">精准还原表格结构</view>
      </view>
      <switch checked="{{enableTableStructure}}" bindchange="onTableChange" color="#3B82F6"/>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="submit-btn" bindtap="handleConvert" disabled="{{!selectedFile || loading}}">
      {{loading ? '解析中...' : '开始解析'}}
    </button>
  </view>
</view>

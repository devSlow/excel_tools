.container {
  min-height: 100%;
  background: #f5f7fa;
  padding: 32rpx;
  box-sizing: border-box;
}

.stats-header {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.3);
}

.task-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
  text-align: center;
}

.stats-summary {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-count {
  font-size: 24rpx;
  color: #999;
}

.column-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.column-option {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.column-option.active {
  background: #1677ff;
  color: #fff;
}

.stats-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stats-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-item:last-child {
  border-bottom: none;
}

.stats-item-left {
  flex: 1;
  display: flex;
  align-items: center;
  position: relative;
  margin-right: 24rpx;
}

.stats-bar {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 48rpx;
  background: linear-gradient(90deg, #1677ff 0%, #4096ff 100%);
  border-radius: 4rpx;
  opacity: 0.2;
}

.stats-label {
  position: relative;
  font-size: 28rpx;
  color: #333;
  z-index: 1;
}

.stats-item-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stats-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.stats-percent {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}